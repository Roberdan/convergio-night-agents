# ============================================
# convergio-night-agents — Environment Variables
# ============================================

# --- Service Configuration ---
# Port for the night agents service
# CONVERGIO_PORT=7777

# --- External Binaries ---
# Path to Claude CLI binary
# CONVERGIO_CLAUDE_BIN=/usr/local/bin/claude

# Path to Python binary
# CONVERGIO_PYTHON=python3

# --- AI Model ---
# MLX model name for local inference
# CONVERGIO_MLX_MODEL=mlx-community/Meta-Llama-3.1-8B-Instruct-4bit
